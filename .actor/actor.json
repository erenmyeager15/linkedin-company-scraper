{
    "actorSpecification": 1,
    "name": "linkedin-company-scraper",
    "title": "LinkedIn Company Scraper - Profiles & Insights",
    "description": "Scrape public LinkedIn company pages: name, description, industry, size, HQ, company type, website, specialties, followers, employee count, and logo. Provide company URLs or names.",
    "version": "1.0",
    "dockerfile": "Dockerfile",
    "input": "../INPUT_SCHEMA.json",
    "pricingInfo": {
        "pricingModel": "PAY_PER_EVENT",
        "pricingPerEvent": {
            "actorChargeEvents": {
                "company-scraped": {
                    "eventTitle": "Company scraped",
                    "eventDescription": "Charged once for each LinkedIn company profile successfully scraped.",
                    "eventPriceUsd": 0.004,
                    "isPrimaryEvent": true,
                    "isOneTimeEvent": false
                }
            }
        }
    },
    "categories": ["SOCIAL_MEDIA", "OTHER"],
    "minMemoryMbytes": 2048,
    "maxMemoryMbytes": 8192,
    "defaultRunOptions": {
        "memoryMbytes": 4096,
        "timeoutSecs": 43200
    },
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "companies": {
                    "title": "Scraped Companies",
                    "transformation": {
                        "fields": [
                            "companyName",
                            "linkedinUrl",
                            "website",
                            "companyDescription",
                            "industry",
                            "companySize",
                            "headquartersLocation",
                            "companyType",
                            "specialties",
                            "followerCount",
                            "employeeCount",
                            "logoUrl",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "companyName": { "label": "Company Name", "format": "text" },
                            "linkedinUrl": { "label": "LinkedIn URL", "format": "link" },
                            "website": { "label": "Website", "format": "link" },
                            "companyDescription": { "label": "Company Description", "format": "text" },
                            "industry": { "label": "Industry", "format": "text" },
                            "companySize": { "label": "Size", "format": "text" },
                            "headquartersLocation": { "label": "HQ", "format": "text" },
                            "companyType": { "label": "Company Type", "format": "text" },
                            "specialties": { "label": "Specialties", "format": "array" },
                            "followerCount": { "label": "Followers", "format": "text" },
                            "employeeCount": { "label": "Employee Count", "format": "text" },
                            "logoUrl": { "label": "Logo URL", "format": "image" },
                            "scrapedAt": { "label": "Scraped At", "format": "date" }
                        }
                    }
                }
            }
        }
    }
}
